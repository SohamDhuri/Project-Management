 {
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "dist/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "server.js"
        }
    ],
    
    "buildCommand": "npm run build",
    
    "functions": {
    "server.js": {
      "includeFiles": "node_modules/.prisma/**"
    }
  }

}
